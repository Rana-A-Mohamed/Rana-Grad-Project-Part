# Frontend env. Copy to `.env`. Vite only exposes VITE_-prefixed vars.

# API base path. In dev this is proxied by Vite to the backend (see vite.config.ts),
# so a relative path avoids CORS. For a deployed build, set the full URL.
VITE_API_BASE_URL=/api/v1

# (dev only) backend the Vite proxy forwards /api to:
VITE_PROXY_TARGET=http://localhost:4000
