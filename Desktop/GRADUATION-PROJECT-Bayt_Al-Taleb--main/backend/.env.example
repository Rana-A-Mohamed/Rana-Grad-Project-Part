# ────────────────────────────────────────────────────────────
#  Bayt Al Taleb — Environment Variables
#  Copy to `.env` and fill in real values. NEVER commit `.env`.
# ────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database (PostgreSQL) — used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bayt_al_taleb?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bayt_al_taleb?schema=public"

# "postgresql://myuser:mypassword@localhost:5432/mydatabase"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7dnpm run prisma:migrate

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25
