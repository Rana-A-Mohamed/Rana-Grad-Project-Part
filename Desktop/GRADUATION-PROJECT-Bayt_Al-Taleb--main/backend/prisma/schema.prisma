// ════════════════════════════════════════════════════════════════════════
//  Bayt Al Taleb (بيت الطالب) — Prisma Schema
//  Foundation schema. Supports: RBAC, polymorphic content (Section/FAQ),
//  and the file upload → review workflow.
//
//  Design notes:
//   - RBAC uses a Role table + RolePermission join so permissions are data,
//     not hard-coded enums. A `RoleName` enum seeds the five canonical roles.
//   - Polymorphic content: ONE `Section` table and ONE `Faq` table serve all
//     entity types via (entityType, entityId). NO MajorSections /
//     ScholarshipSections tables — exactly one generic system.
//   - File workflow: File.status drives state; FileReview is the audit trail.
// ════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

/// Canonical roles. Used to seed the Role table; the actual authorization
/// decisions read from Role + RolePermission so new roles need no code change.
enum RoleName {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  MEMBER
  VISITOR
}

/// The kind of entity a polymorphic Section / Faq attaches to.
/// Extend this enum (e.g. COURSE, JOB) to reuse the content system elsewhere.
enum ContentEntityType {
  MAJOR
  SCHOLARSHIP
}

/// The kind of entity a file belongs to. Mirrors the polymorphic strategy of
/// ContentEntityType — extend this enum (e.g. COURSE, JOB) to attach files to
/// new owner types without new tables or schema redesign.
enum FileOwnerType {
  MAJOR
  SCHOLARSHIP
}

enum FileType {
  SUMMARY
  PREVIOUS_EXAM
  SYLLABUS
  OTHER
}

enum FileStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewAction {
  APPROVE
  REJECT
}

/// Actions recorded in the audit log. CREATE/UPDATE/DELETE/RESTORE cover the
/// soft-delete lifecycle; APPROVE/REJECT cover the file review workflow.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  APPROVE
  REJECT
}

/// Entity kinds that participate in soft delete / the deleted-items queue and
/// are referenced by audit logs. A superset that also covers non-soft-deletable
/// audited entities is fine — this enum is the audit/queue vocabulary.
enum AuditEntityType {
  MAJOR
  SCHOLARSHIP
  FILE
  SECTION
  FAQ
}

// ───────────────────────────── RBAC ──────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

/// A permission is a stable string key, e.g. "files:approve", "majors:manage".
/// Storing permissions as data keeps RBAC extensible without migrations.
model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ───────────────────────────── Users ─────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  refreshTokens RefreshToken[]
  uploadedFiles File[]         @relation("UploadedBy")
  reviews       FileReview[]   @relation("ReviewedBy")
  auditLogs     AuditLog[]     @relation("AuditActor")
  notifications Notification[]

  // Moderators are assigned to specific majors / scholarships.
  assignedMajors       Major[]       @relation("MajorModerators")
  assignedScholarships Scholarship[] @relation("ScholarshipModerators")

  @@index([roleId])
  @@map("users")
}

/// Persisted refresh tokens enable rotation & server-side logout/revocation.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────── Domain: Colleges / Majors / Scholarships ─
// These tables hold ONLY identity/metadata. All rich, template-style
// content lives in the polymorphic Section / Faq tables below — content
// stays attached to majors, never to colleges.

/// A college groups many majors (e.g. Engineering → Civil, Architecture).
model College {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  majors Major[]

  @@map("colleges")
}

model Major {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  degree    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optional parent college. Nullable so existing flat majors keep working;
  // assigning a college groups the major under it (One College → Many Majors).
  collegeId String?
  college   College? @relation(fields: [collegeId], references: [id])

  // Soft delete — a non-null deletedAt hides the row from public APIs and
  // places it in the deleted-items queue. The row is never physically removed
  // until a Super Admin permanently deletes it.
  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?

  moderators User[] @relation("MajorModerators")

  @@index([deletedAt])
  @@index([collegeId])
  @@map("majors")
}

model Scholarship {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?

  moderators User[] @relation("ScholarshipModerators")

  @@index([deletedAt])
  @@map("scholarships")
}

// ─────────────────── Polymorphic Content System ──────────────────
// ONE Section table + ONE Faq table for ALL entity types.
// Referential integrity to the owning row is enforced in the service
// layer (polymorphic FKs are not expressible in SQL). The (entityType,
// entityId) composite index keeps lookups fast.

model Section {
  id         String            @id @default(cuid())
  entityType ContentEntityType
  entityId   String
  title      String
  content    String            @db.Text
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?

  @@index([entityType, entityId])
  @@index([entityType, entityId, sortOrder])
  @@index([deletedAt])
  @@map("sections")
}

model Faq {
  id         String            @id @default(cuid())
  entityType ContentEntityType
  entityId   String
  question   String
  answer     String            @db.Text
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?

  @@index([entityType, entityId])
  @@index([deletedAt])
  @@map("faqs")
}

// ───────────────────── Files & Review Workflow ───────────────────

model File {
  id           String     @id @default(cuid())
  title        String
  description  String?
  type         FileType
  status       FileStatus @default(PENDING)
  storageKey   String // path / object key in the storage backend
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Polymorphic owner — every file belongs to exactly one domain entity
  // (major, scholarship, …). Same strategy as Section/Faq: no per-owner
  // tables, no nullable FKs. Existence is enforced in the service layer.
  ownerType    FileOwnerType
  ownerId      String

  uploadedById String
  uploadedBy   User   @relation("UploadedBy", fields: [uploadedById], references: [id])

  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?

  reviews FileReview[]

  @@index([uploadedById])
  @@index([status])
  @@index([type])
  @@index([ownerType, ownerId])
  @@index([ownerType, ownerId, type])
  @@index([deletedAt])
  @@map("files")
}

model FileReview {
  id        String       @id @default(cuid())
  fileId    String
  reviewerId String
  action    ReviewAction
  comment   String?
  createdAt DateTime     @default(now())

  file     File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewedBy", fields: [reviewerId], references: [id])

  @@index([fileId])
  @@index([reviewerId])
  @@map("file_reviews")
}

// ───────────────────────────── Contact ───────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  isHandled Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isHandled])
  @@map("contact_messages")
}

// ───────────────────────────── Audit Log ─────────────────────────
// Centralized, append-only record of every important action. Written ONLY
// through AuditService. `metadata` is free-form JSON (e.g. changed fields,
// previous status). Never updated or deleted in normal operation.

model AuditLog {
  id         String          @id @default(cuid())
  userId     String
  action     AuditAction
  entityType AuditEntityType
  entityId   String
  reason     String?
  metadata   Json?
  createdAt  DateTime        @default(now())

  user User @relation("AuditActor", fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────── Notifications ───────────────────────
// In-app notifications delivered to a specific user. Created by
// NotificationService (directly or auto-triggered by review/restore/role
// changes). No emails/push — purely in-app for now.

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}
